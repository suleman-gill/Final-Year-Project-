# Tilawah AI - Production Environment Template
ENVIRONMENT=production

# Security
SECRET_KEY=generate_a_very_secure_long_random_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# Database & Redis
DATABASE_URL=postgresql://user:password@db_host:5432/tilawah_db
REDIS_URL=redis://redis_host:6379/0

# Rate Limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=60/minute

# ML Model (Optional: Leave blank to use FallbackCalculatedEngine)
MODEL_PATH=

# External Services
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Sentry DSN
SENTRY_DSN=your_sentry_dsn
